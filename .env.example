# Your PoE account session cookie (grab from browser devtools → Application → Cookies)
POE_SESSION_ID=your_poesessid_here

# Path to SQLite database file
DATABASE_PATH=data/poe2_tablets.db

# How often to run a full snapshot cycle (minutes)
SNAPSHOT_INTERVAL_MINUTES=60

# Price floors (divine) — magic uses 0 to collect cheap bases
PRICE_MIN_DIVINE_RARE=1.0
PRICE_MIN_DIVINE_MAGIC=0.0
PRICE_MIN_DIVINE_NORMAL=0.0

# Currency normalization (update to match your league economy)
CHAOS_PER_DIVINE=200.0
EXALT_PER_DIVINE=0.05
REGAL_COST_DIVINE=0.02

# Buy signal thresholds (tune after data collection)
BUY_SIGNAL_MIN_PROFIT_DIV=1.0
BUY_SIGNAL_MAX_JUNK_RATE=0.30
BUY_SIGNAL_MIN_CONFIDENCE=0.60

# Auto-detect current league on startup
CURRENT_LEAGUE_AUTO=true

# Archive previous league data on rollover
ARCHIVE_ON_LEAGUE_RESET=true

# API server (embedded in scheduler when ENABLE_API=true)
ENABLE_API=true
API_HOST=0.0.0.0
API_PORT=8001

# Logging level: DEBUG, INFO, WARNING, ERROR
LOG_LEVEL=INFO

# Optional: hardcode league name (only used when CURRENT_LEAGUE_AUTO=false)
# LEAGUE_NAME=Standard

# CORS origins (comma-separated list of allowed origins)
# For local development: CORS_ORIGINS=*
# For production with GitHub Pages: CORS_ORIGINS=https://yourusername.github.io
# For multiple origins: CORS_ORIGINS=http://localhost:3000,https://your-site.github.io
CORS_ORIGINS=*

# API base URL for frontend (optional)
# When frontend and backend are separated (e.g., GitHub Pages + Fly.io):
# Set this in your frontend deployment, not here.
# For local development, leave empty to use relative paths.
# API_BASE_URL=

# Note: API_BASE_URL is configured in frontend JavaScript, not in this backend config.
# To set it, add this before loading your page:
#   <script>window.API_CONFIG = { apiBaseUrl: "https://your-backend.fly.dev" };</script>
